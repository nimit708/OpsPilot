# Runtime
PORT=3080
HOST=127.0.0.1
TLS_CERT_PATH=
TLS_KEY_PATH=
# Set true only when a trusted platform (for example Render) terminates HTTPS.
EXTERNAL_HTTPS=false
APP_MODE=demo
ACTION_POLICY=approval
AUTO_CONFIDENCE=0.90
# slack, teams, or both
TRIAGE_PROVIDER=slack
ADMIN_API_TOKEN=replace-with-a-long-random-token

# Dashboard sign-in: register a Microsoft web app supporting personal + work accounts
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_AUTHORITY=common
MS_OAUTH_REDIRECT_URI=https://localhost:3080/auth/callback
SECURE_COOKIES=true
SESSION_HOURS=8
ADMIN_EMAILS=you@outlook.com
APPROVER_EMAILS=

# Workplace privacy governance (replace with your approved legal basis)
PRIVACY_POLICY_VERSION=2026-07-18
REQUIRE_EMPLOYEE_CONSENT=true
MONITORING_LAWFUL_BASIS=legitimate-interests-subject-to-approved-dpia
DATA_RETENTION_DAYS=30

# Monitoring
LOG_LEVEL=info
METRICS_TOKEN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# AI classification
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Jira Cloud (API token + account email)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_ISSUE_TYPE=Task

# Confluence Cloud REST v2 (can reuse the Jira Cloud account/token)
CONFLUENCE_BASE_URL=https://your-company.atlassian.net
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_ID=123456
CONFLUENCE_PARENT_PAGE_ID=
WORKFLOW_WEBHOOK_SECRET=replace-with-an-independent-webhook-secret

# Slack bot: chat:write and relevant channels:history scopes
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_IDS=C0123456789,C0987654321

# Microsoft Entra application credentials
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
TEAMS_TEAM_ID=
TEAMS_CHANNEL_IDS=19:channel-id@thread.tacv2
OUTLOOK_SENDER=opspilot@your-company.com
# Teams Workflow/Incoming Webhook used when TRIAGE_PROVIDER=teams or both
TEAMS_TRIAGE_WEBHOOK_URL=

# Per-team destinations (Slack values must be channel IDs, not names)
ROUTE_PAYMENTS_JIRA=PAY
ROUTE_PAYMENTS_SLACK=C0123456789
ROUTE_PAYMENTS_EMAIL=payments@your-company.com
ROUTE_PLATFORM_JIRA=PLAT
ROUTE_PLATFORM_SLACK=C0123456789
ROUTE_PLATFORM_EMAIL=platform@your-company.com
ROUTE_IDENTITY_JIRA=IAM
ROUTE_IDENTITY_SLACK=C0123456789
ROUTE_IDENTITY_EMAIL=identity@your-company.com
ROUTE_SUPPORT_JIRA=SUP
ROUTE_SUPPORT_SLACK=C0123456789
ROUTE_SUPPORT_EMAIL=support@your-company.com

# Optional in-process scheduler (use one replica only; production can use an external scheduler)
SCHEDULER_ENABLED=false
POLL_INTERVAL_MS=300000
EOD_HOUR=17
